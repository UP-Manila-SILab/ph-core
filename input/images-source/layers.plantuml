@startuml
!theme plain
skinparam backgroundColor #FEFEFE
skinparam packageStyle rectangle
skinparam linetype ortho
skinparam wrapWidth 150

' Make the diagram more compact and vertical
skinparam class {
    BackgroundColor #FEFEFE
    BorderColor #999999
    FontSize 11
}

skinparam package {
    BackgroundColor #FEFEFE
    BorderColor #666666
    FontSize 12
}

skinparam note {
    BackgroundColor #FFFFCC
    BorderColor #999999
    FontSize 10
}

title PH Core IG Architecture Layers

' === R4 BASE LAYER (Blue) ===
package "FHIR R4 Base" <<Layer>> #E3F2FD {
    rectangle "Patient" as R4Patient
    rectangle "Practitioner" as R4Practitioner
    rectangle "Organization" as R4Organization
    rectangle "Encounter" as R4Encounter
    rectangle "Observation" as R4Observation
    rectangle "Condition" as R4Condition
    rectangle "Medication" as R4Medication
    rectangle "Claim" as R4Claim

    ' Force vertical stack
    R4Patient -[hidden]down-> R4Practitioner
    R4Practitioner -[hidden]down-> R4Organization
    R4Organization -[hidden]down-> R4Encounter
    R4Encounter -[hidden]down-> R4Observation
    R4Observation -[hidden]down-> R4Condition
    R4Condition -[hidden]down-> R4Medication
    R4Medication -[hidden]down-> R4Claim

    note right
        HL7 FHIR R4.0.1
        Foundation Resources
    end note
}

' === PH CORE LAYER (Green) ===
package "PH Core IG" <<Layer>> #E8F5E9 {

    package "Profiles" #C8E6C9 {
        rectangle "Patient" as PHCorePatient
        rectangle "Practitioner" as PHCorePractitioner
        rectangle "Organization" as PHCoreOrganization
        rectangle "Encounter" as PHCoreEncounter
        rectangle "Observation" as PHCoreObservation
        rectangle "Condition" as PHCoreCondition
        rectangle "Medication" as PHCoreMedication
        rectangle "Claim" as PHCoreClaim
        rectangle "Procedure" as PHCoreProcedure
        rectangle "Immunization" as PHCoreImmunization
        rectangle "AllergyIntolerance" as PHCoreAllergyIntolerance
        rectangle "ServiceRequest" as PHCoreServiceRequest
        rectangle "Task" as PHCoreTask
        rectangle "Provenance" as PHCoreProvenance
        rectangle "...(12 more)" as MoreProfiles

        PHCorePatient -[hidden]down-> PHCorePractitioner
        PHCorePractitioner -[hidden]down-> PHCoreOrganization
        PHCoreOrganization -[hidden]down-> PHCoreEncounter
        PHCoreEncounter -[hidden]down-> PHCoreObservation
        PHCoreObservation -[hidden]down-> PHCoreCondition
        PHCoreCondition -[hidden]down-> PHCoreMedication
        PHCoreMedication -[hidden]down-> PHCoreClaim
        PHCoreClaim -[hidden]down-> PHCoreProcedure
        PHCoreProcedure -[hidden]down-> PHCoreImmunization
        PHCoreImmunization -[hidden]down-> PHCoreAllergyIntolerance
        PHCoreAllergyIntolerance -[hidden]down-> PHCoreServiceRequest
        PHCoreServiceRequest -[hidden]down-> PHCoreTask
        PHCoreTask -[hidden]down-> PHCoreProvenance
        PHCoreProvenance -[hidden]down-> MoreProfiles
    }

    package "Extensions" #C8E6C9 {
        rectangle "Barangay" as ExtBarangay
        rectangle "City/Municipality" as ExtCityMun
        rectangle "Province" as ExtProvince
        rectangle "Region" as ExtRegion
        rectangle "IndigenousGroup" as ExtIndigenous
        rectangle "PWDDisability" as ExtPWD
        rectangle "...(7 more)" as MoreExtensions

        ExtBarangay -[hidden]down-> ExtCityMun
        ExtCityMun -[hidden]down-> ExtProvince
        ExtProvince -[hidden]down-> ExtRegion
        ExtRegion -[hidden]down-> ExtIndigenous
        ExtIndigenous -[hidden]down-> ExtPWD
        ExtPWD -[hidden]down-> MoreExtensions
    }

    package "Terminology" #C8E6C9 {
        package "CodeSystems" #A5D6A7 {
            rectangle "PSGC" as CS_PSGC
            rectangle "PSOC" as CS_PSOC
            rectangle "PSCED" as CS_PSCED
            rectangle "Drugs" as CS_Drugs

            CS_PSGC -[hidden]down-> CS_PSOC
            CS_PSOC -[hidden]down-> CS_PSCED
            CS_PSCED -[hidden]down-> CS_Drugs
        }
        package "ValueSets" #A5D6A7 {
            rectangle "Regions" as VS_Regions
            rectangle "Provinces" as VS_Provinces
            rectangle "Cities" as VS_Cities
            rectangle "Barangays" as VS_Barangays

            VS_Regions -[hidden]down-> VS_Provinces
            VS_Provinces -[hidden]down-> VS_Cities
            VS_Cities -[hidden]down-> VS_Barangays
        }
    }

    package "Identifiers & Actors" #C8E6C9 {
        rectangle "PhilHealthID" as ID_PhilHealth
        rectangle "PhilSysID" as ID_PhilSys
        rectangle "Server" as ActorServer
        rectangle "Consumer" as ActorConsumer
        rectangle "Creator" as ActorCreator

        ID_PhilHealth -[hidden]down-> ID_PhilSys
        ID_PhilSys -[hidden]down-> ActorServer
        ActorServer -[hidden]down-> ActorConsumer
        ActorConsumer -[hidden]down-> ActorCreator
    }

    ' Stack inner packages vertically
    Profiles -[hidden]down-> Extensions
    Extensions -[hidden]down-> Terminology
    Terminology -[hidden]down-> Identifiers
}

' === PROGRAM IGs LAYER (Orange) ===
package "Program-Specific IGs" <<Layer>> #FFF3E0 {
    package "Downstream Profiles" #FFE0B2 {
        rectangle "Patient" as DownstreamPatient
        rectangle "Encounter" as DownstreamEncounter
        rectangle "...(other profiles)" as DownstreamMore

        DownstreamPatient -[hidden]down-> DownstreamEncounter
        DownstreamEncounter -[hidden]down-> DownstreamMore
    }
}

' === INHERITANCE / RELATIONSHIP ARROWS ===
PHCorePatient --down-|> R4Patient
PHCorePractitioner --down-|> R4Practitioner
PHCoreOrganization --down-|> R4Organization
PHCoreEncounter --down-|> R4Encounter
PHCoreObservation --down-|> R4Observation
PHCoreCondition --down-|> R4Condition
PHCoreMedication --down-|> R4Medication
PHCoreClaim --down-|> R4Claim

DownstreamPatient --up-|> PHCorePatient
DownstreamEncounter --up-|> PHCoreEncounter

' === EXTENSION USAGE ===
ExtBarangay ..> PHCorePatient : extends
ExtProvince ..> PHCorePatient : extends

note right of PHCorePatient
    PH Core profiles inherit
    from FHIR R4 and add
    PH-specific constraints
    (e.g., identifiers,
    address extensions)
end note

note right of DownstreamPatient
    Downstream IGs inherit
    from PH Core and add
    program-specific
    constraints
end note

legend right
    |= Color |= Meaning |
    | <#E3F2FD> | FHIR R4 Base Resources |
    | <#E8F5E9> | PH Core Artifacts |
    | <#FFF3E0> | Program-Specific IGs |
endlegend

@enduml
